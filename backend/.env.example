# Database (Postgres example - MySQL also supported, see app/config.py)
DATABASE_URL=postgresql://postgres:machu@localhost:5432/medical
# For MySQL instead, use:
# DATABASE_URL=mysql+pymysql://hcp_crm:machu@localhost:3306/hcp_crm

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=gemma2-9b-it
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# App
BACKEND_CORS_ORIGINS=http://localhost:5173
ENV=development
